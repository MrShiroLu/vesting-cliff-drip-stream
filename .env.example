# ──────────────────────────────────────────────────────────────────────────────
# Vesting Cliff Drip Stream — Backend Environment Variables
# Copy this file to .env and fill in the values for your environment.
# See docs/config.md for full descriptions and accepted values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Horizon REST API endpoint
HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar network passphrase (must match the network the contract is deployed on)
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban contract ID of the deployed vesting_cliff_drip_stream contract
CONTRACT_ID=

# ── Required for POST /admin/bulk-claim ───────────────────────────────────────

# Bearer token for admin endpoint authentication (use a strong random secret)
ADMIN_API_KEY=

# Stellar secret key (S...) of the account that signs claim transactions
SPONSOR_SECRET_KEY=

# Soroban RPC endpoint for transaction submission
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Optional ──────────────────────────────────────────────────────────────────

# HTTP server port (default: 3000)
# PORT=3000

# Log verbosity: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Soroban RPC response timeout in milliseconds (default: 30000)
# REQUEST_TIMEOUT_MS=30000
