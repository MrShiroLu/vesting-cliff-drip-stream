{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GetVestingSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:vesting/db-password-*",
        "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:vesting/rpc-key-*",
        "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:vesting/jwt-secret-*"
      ]
    }
  ]
}
